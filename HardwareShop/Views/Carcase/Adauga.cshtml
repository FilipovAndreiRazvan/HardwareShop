@model HardwareShop.Models.Carcasa
@{
    ViewBag.Title = "Adauga produs";
}

<link rel="stylesheet" href="~/Content/AdaugaProdus.css" type="text/css" />
<main aria-labelledby="title">
    <h2 id="title">@ViewBag.Title</h2>
    @using (Html.BeginForm("Salvare", "Carcase", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { role = "form" }))
    {
        @Html.ValidationSummary(true, "Please fix the following errors.")
        <div class="fields">
            <div class="field">
                @Html.LabelFor(m => m.Nume, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.Nume, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Nume, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.Pret, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.Pret, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Pret, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.format, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.format, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.format, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.nrVentilatoare, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.nrVentilatoare, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.nrVentilatoare, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.deschidereLaterala, new { @class = " col-form-label" })
                <div class="input">
                    @Html.DropDownListFor(m => m.deschidereLaterala, new List<SelectListItem> { new SelectListItem { Text = "Da", Value = "true" }, new SelectListItem { Text = "Nu", Value = "false" } }, new { @class = "dropdown-item" })
                    @Html.ValidationMessageFor(m => m.deschidereLaterala, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.tipCarcasa, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.tipCarcasa, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.tipCarcasa, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.nrLocaseSloturiExtensii, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.nrLocaseSloturiExtensii, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.nrLocaseSloturiExtensii, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.dimensiune, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.dimensiune, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.dimensiune, "", new { @class = "text-danger" })
                    <p>(LungimexLatimexInaltime)</p>
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.greutate, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.greutate, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.greutate, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.culoare, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.culoare, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.culoare, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.stoc, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.stoc, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.stoc, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.Descriere, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.Descriere, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Descriere, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.imgLink, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.imgLink, new { type = "file", @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.stoc, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>
        <div class="button">
            <input type="submit" value="Adauga" class=" submit btn btn-outline-dark" />
        </div>
    }
</main>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}