@model HardwareShop.Models.GPU
@{
    ViewBag.Title = "Adauga produs";
}

<link rel="stylesheet" href="~/Content/AdaugaProdus.css" type="text/css" />
<main aria-labelledby="title">
    <h2 id="title">@ViewBag.Title</h2>
    @using (Html.BeginForm("Salvare", "PlaciVideo", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { role = "form" }))
    {
        @Html.ValidationSummary(true, "Please fix the following errors.")
        <div class="fields">
            <div class="field">
                @Html.LabelFor(m => m.Nume, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.Nume, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Nume, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.Pret, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.Pret, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Pret, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.CapacitateMemorie, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.CapacitateMemorie, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.CapacitateMemorie, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.FrecventaMemorie, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.FrecventaMemorie, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.FrecventaMemorie, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.RezolutieMaxima, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.RezolutieMaxima, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.RezolutieMaxima, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.SistemRacire, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.SistemRacire, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.SistemRacire, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.stoc, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.stoc, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.stoc, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.Descriere, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.Descriere, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Descriere, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="field">
                @Html.LabelFor(m => m.imgLink, new { @class = "col-form-label" })
                <div class="input">
                    @Html.TextBoxFor(m => m.imgLink, new { type = "file", @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.stoc, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>
        <div class="button">
            <input type="submit" value="Adauga" class=" submit btn btn-outline-dark" />
        </div>
    }
</main>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
