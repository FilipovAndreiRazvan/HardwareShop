@model List<HardwareShop.Models.Cerere>
<style>
    .raspunsCerere {
        width: 40%;
        text-decoration: none;
        color: white;
        font-weight: 600;
        background: #71c16a;
        background-size: 20px;
        padding: 8px 0;
        text-align:center;
        transition: background-color 0.5s;
        font-size: 18px;
    }



        .raspunsCerere:hover {
            color: white;
            background-color: orangered;
        }

    .cerere {
        border: 2px solid black;
        margin-left: 10px;
        height: auto;
        width: 25%;
        padding: 20px 0;
    }

    .lista {
        width: 80%;
        margin:10px auto;
    }
    .raspuns{
        display:flex;
        justify-content:space-between;
        width:80%;
        margin:0 auto;
    }
    .cerere h2{
        text-align:center;
    }
</style>
<h1>Cereri</h1>
@foreach (var cerere in Model)
{
    <div class="cerere">
        <h2>@cerere.Utilizator.Nume @cerere.Utilizator.Prenume</h2>
        <h3>Tip cerere:@cerere.tipCerere</h3>
        <ul class="lista">
            @if (cerere.tipCerere == "Furnizor nou")
            {
                <li>Oras:@cerere.Oras</li>
                <li>Brand:@cerere.Brand</li>
                <li>CUI:@cerere.CUI</li>
            }

            <li>
                Produse oferite:
                <ul>
                    @if (cerere.Carcase == true)
                    {
                        <li>Carcase </li>
                    }
                    @if (cerere.placiDeBaza == true)
                    {
                        <li>Placi de baza </li>
                    }
                    @if (cerere.procesoare == true)
                    {
                        <li>Procesoare </li>
                    }
                    @if (cerere.placiVideo == true)
                    {
                        <li>Placi video </li>
                    }
                    @if (cerere.placuteRAM == true)
                    {
                        <li>Placute RAM </li>
                    }
                    @if (cerere.unitatiDeStocare == true)
                    {
                        <li>Unitati de stocare </li>
                    }
                    @if (cerere.surse == true)
                    {
                        <li>Surse de alimentare </li>
                    }
                    @if (cerere.pastaProcesor == true)
                    {
                        <li>Pasta pentru procesoare </li>
                    }
                </ul>
            </li>
        </ul>
        <div class="raspuns">
            <a class="raspunsCerere" href=@Url.Action("Raspuns","Cerere",new {cerereId = cerere.Id,cerereAcceptata = false,userId = cerere.Utilizator.Id})>
                Respinge
            </a>
            <a class="raspunsCerere" href=@Url.Action("Raspuns","Cerere",new {cerereId = cerere.Id,cerereAcceptata = true,userId = cerere.Utilizator.Id})>
                Accepta
            </a>
        </div>
    </div>
}
