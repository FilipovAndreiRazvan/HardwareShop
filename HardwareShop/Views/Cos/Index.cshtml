                            </div>
                        </div>
                    </div>
                }
            }
            @if (Model.pastaCPU.Count > 0)
            {
                foreach (var pasta in Model.pastaCPU)
                {
                    pretTotal += pasta.Pret;
                    var pretInt = (int)pasta.Pret;
                    var pretDec = (int)((pasta.Pret - Math.Floor(pasta.Pret)) * 100);

                    <div class="produs">
                        <div class="img">
                            <img src="~/@pasta.imgLink" />
                        </div>
                        <div class="text">
                            <h1>@Html.ActionLink(pasta.Nume, "Vizualizare", "PastaProcesor", new { id = pasta.Id }, null)</h1>
                            <div class="detalii">
                                <p>Vandut de :HardwareShop</p>
                            </div>
                            <div class="cumpara">
                                <p class="pret">
                                    @pretInt
                                    @if (pretDec > 0)
                                    {
                                        <sup>@pretDec</sup>
                                    }
                                    Lei
                                </p>
                                <a class="adaugaProdus" href="@Url.Action("Sterge","Cos",new {id = pasta.Id,categorie = "pastaCPU",nrBuc = 1})">Stergere produs</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
        <div class="sumarComanda">
            @{
                var pretIntreg = (int)pretTotal;
                var pretDecimal = (int)((pretTotal - Math.Floor(pretTotal)) * 100);
            }
            <h1>Sumar comanda</h1>
            <div class="costuri">
                <p class="p1">Cost produse:</p>
                <p class="p2">
                    @pretIntreg
                    @if (pretDecimal != 0)
                    {
                        <sup>@pretDecimal</sup>
                    }
                    Lei
                </p>
                <p class="p3" title="Livrare gratuita la comenzi de minim 2000 de lei">Cost livrare*:</p>
                @if (pretTotal > 2000)
                {
                    <p class="livrareGratis">GRATUIT</p>
                }
                else
                {
                    pretTotal += 30;
                    <p class="p4">30 Lei</p>
                }
            </div>
            <div class="total">
                <p class="p5">Total:</p>
                @{
                    pretIntreg = (int)pretTotal;
                    pretDecimal = (int)((pretTotal - Math.Floor(pretTotal)) * 100);
                }
                <p class="p6">
                    @pretIntreg
                    @if (pretDecimal != 0)
                    {
                        <sup>@pretDecimal</sup>
                    }
                    Lei
                </p>
            </div>
            <a href="@Url.Action("DetaliiComanda","Comanda")">Continua</a>
        </div>
    }
</main>
<script>
    function stergeMesaj() {
        var mesaj = document.getElementsByClassName("cosGol");
        mesaj[0].style.opacity = "0";
    }
</script>
