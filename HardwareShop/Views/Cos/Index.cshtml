                {
                    pretTotal += sursa.Pret;
                    var pretInt = (int)sursa.Pret;
                    var pretDec = (int)((sursa.Pret - Math.Floor(sursa.Pret)) * 100);

                    <div class="produs">
                        <div class="img">
