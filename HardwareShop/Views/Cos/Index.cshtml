    {
        <div class="produse">
            @if (Model.carcase.Count > 0)
            {

                foreach (var carcasa in Model.carcase)
                {
                    pretTotal += carcasa.Pret;
                    var pretInt = (int)carcasa.Pret;
                    var pretDec = (int)((carcasa.Pret - Math.Floor(carcasa.Pret)) * 100);

                    <div class="produs">
                        <div class="img">
                            <img src="~/@carcasa.imgLink" />
                        </div>
                        <div class="text">
                            <h1>@Html.ActionLink(carcasa.Nume, "Vizualizare", "Carcase", new { id = carcasa.Id }, null)</h1>
                            <div class="detalii">
                                <p>Vandut de :HardwareShop</p>
                            </div>
                            <div class="cumpara">
                                <p class="pret">
                                    @pretInt
                                    @if (pretDec > 0)
                                    {
                                        <sup>@pretDec</sup>
                                    }
                                    Lei
                                </p>
                                <a class="adaugaProdus" href="@Url.Action("Sterge","Cos",new {id = carcasa.Id,categorie = "carcase",nrBuc = 1})">Stergere produs</a>
                            </div>
                        </div>
                    </div>


                }
            }
            @if (Model.motherboard.Count > 0)
            {
                foreach (var motherboard in Model.motherboard)
                {
                    pretTotal += motherboard.Pret;
                    var pretInt = (int)motherboard.Pret;
                    var pretDec = (int)((motherboard.Pret - Math.Floor(motherboard.Pret)) * 100);
                    <div class="produs">
                        <div class="img">
                            <img src="~/@motherboard.imgLink" />
                        </div>
                        <div class="text">
                            <h1>@Html.ActionLink(motherboard.Nume, "Vizualizare", "PlaciDeBaza", new { id = motherboard.Id }, null)</h1>
                            <div class="detalii">
                                <p>Vandut de :HardwareShop</p>
                            </div>
                            <div class="cumpara">
                                <p class="pret">
                                    @pretInt
                                    @if (pretDec > 0)
                                    {
                                        <sup>@pretDec</sup>
                                    }
                                    Lei
                                </p>
                                <a class="adaugaProdus" href="@Url.Action("Sterge","Cos",new {id = motherboard.Id,categorie = "placiDeBaza",nrBuc = 1})">Stergere produs</a>
                            </div>
                        </div>
                    </div>
                }
            }
            @if (Model.cpu.Count > 0)
            {
                foreach (var procesor in Model.cpu)
